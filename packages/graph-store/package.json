{
  "name": "@aikb/graph-store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aikb/core-config": "workspace:*",
    "@aikb/core-embeddings": "workspace:*",
    "@aikb/core-types": "workspace:*",
    "neo4j-driver": "^5.19.0",
    "openai": "^4.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "tsup": "*",
    "typescript": "*",
    "vitest": "*"
  }
}
